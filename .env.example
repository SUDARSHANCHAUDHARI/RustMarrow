GITHUB_TOKEN=your_github_pat_here
GITHUB_USERNAME=SUDARSHANCHAUDHARI
ANTHROPIC_API_KEY=your_anthropic_key_here
MARROW_DB_PATH=~/.marrow/marrow.db
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# Google OAuth2 — shared by Gmail + Calendar
# Get from Google Cloud Console → OAuth2 credentials (Desktop app type)
# Run `marrow auth google` once to exchange the auth code for a refresh token
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# Slack — user token (xoxp-) with channels:read, channels:history, im:read, im:history
SLACK_TOKEN=xoxp-your-token-here
# Optional: comma-separated channel IDs to restrict to (e.g. C123456,C789012)
# If not set, pulls all channels the token has access to
# SLACK_CHANNELS=C123456,C789012
